<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
<meta name="theme-color" content="#0b0b10">
<title>Pinecon Instagram likes — 2020+ auto embeds + month slider</title>
<!-- Header behavior: Pinecon title/header and list title now scroll away normally. Added left-side vertical page scroller for fast top/bottom movement. -->
<style>
:root {
  --bg:#08080d;
  --panel:#12131b;
  --panel2:#171823;
  --panel3:#0f1018;
  --text:#f6f6fb;
  --muted:#b8b8c8;
  --soft:#7f8192;
  --line:#2a2c3a;
  --accent:#ff3d87;
  --accent2:#f7b733;
  --violet:#8b5cff;
  --good:#44d889;
  --danger:#ff5e5e;
  --radius:18px;
  --safe-bottom:env(safe-area-inset-bottom,0px);
}
* { box-sizing:border-box; }
html, body {
  margin:0;
  padding:0;
  background:var(--bg);
  color:var(--text);
  font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Arial,sans-serif;
  font-size:15px;
  line-height:1.42;
  -webkit-text-size-adjust:100%;
  touch-action:manipulation;
}
html { scroll-behavior:smooth; }
body {
  overflow-y:auto;
  overscroll-behavior-y:contain;
  padding-bottom:calc(86px + var(--safe-bottom));
}
a { color:#a9d0ff; text-decoration:none; overflow-wrap:anywhere; }
button, select, input { font:inherit; }
button, .btn {
  border:1px solid var(--line);
  background:#202231;
  color:var(--text);
  border-radius:999px;
  padding:10px 13px;
  min-height:44px;
  cursor:pointer;
  text-decoration:none;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  gap:6px;
  -webkit-tap-highlight-color:transparent;
  user-select:none;
}
button:active, .btn:active { transform:translateY(1px) scale(.99); }
button.primary, .btn.primary { border-color:rgba(255,61,135,.65); background:linear-gradient(135deg,#ff3d87,#8b5cff); color:white; }
button.good, .btn.good { border-color:rgba(68,216,137,.5); background:#143522; color:#dcffe9; }
button.ghost, .btn.ghost { background:#10111a; }
button.small, .btn.small { min-height:38px; padding:8px 11px; font-size:13px; }
button:disabled { opacity:.42; cursor:not-allowed; transform:none; }
input, select {
  width:100%;
  border:1px solid var(--line);
  border-radius:14px;
  background:#0c0d14;
  color:var(--text);
  padding:12px 13px;
  min-height:46px;
  outline:none;
}
input:focus, select:focus { border-color:rgba(255,61,135,.75); box-shadow:0 0 0 3px rgba(255,61,135,.14); }
input[type="range"] { padding:0; min-height:32px; accent-color:var(--accent); }
.app { max-width:980px; margin:0 auto; padding:12px; }
.topbar {
  position:relative;
  top:auto;
  z-index:auto;
  background:linear-gradient(180deg,rgba(8,8,13,.98),rgba(8,8,13,.93));
  backdrop-filter:blur(10px);
  -webkit-backdrop-filter:blur(10px);
  border-bottom:1px solid var(--line);
  padding:10px 0 12px;
}
.hero {
  border:1px solid var(--line);
  border-radius:var(--radius);
  background:radial-gradient(circle at top left,rgba(255,61,135,.22),transparent 30%),linear-gradient(135deg,#151622,#0f1018);
  padding:14px;
  box-shadow:0 16px 42px rgba(0,0,0,.22);
}
.hero-head { display:flex; align-items:flex-start; justify-content:space-between; gap:10px; }
h1 { margin:0 0 6px; font-size:23px; line-height:1.12; letter-spacing:-.03em; }
.sub { color:var(--muted); font-size:13px; margin:0; }
.stats { display:grid; grid-template-columns:repeat(4,minmax(0,1fr)); gap:8px; margin-top:12px; }
.stat { border:1px solid var(--line); border-radius:14px; padding:9px 10px; background:rgba(255,255,255,.035); min-width:0; }
.stat b { display:block; font-size:16px; line-height:1.05; }
.stat span { color:var(--muted); font-size:11px; }
.controls { display:grid; gap:9px; margin-top:10px; }
label { display:block; color:var(--muted); font-size:12px; font-weight:700; letter-spacing:.01em; }
label > select, label > input { margin-top:5px; }
.row { display:flex; gap:8px; align-items:center; }
.row > * { flex:1; }
.month-row { display:none; }
.month-slider-panel {
  margin-top:9px;
  border:1px solid var(--line);
  background:linear-gradient(180deg,rgba(255,255,255,.045),rgba(255,255,255,.02));
  border-radius:18px;
  padding:10px;
}
.month-slider-top {
  display:grid;
  grid-template-columns:auto 1fr auto;
  gap:9px;
  align-items:center;
}
.slider-month-label { text-align:center; min-width:0; }
.slider-month-label b { display:block; font-size:14px; line-height:1.1; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.slider-month-label small { display:block; color:var(--muted); font-size:11px; margin-top:2px; }
.range-wrap { display:grid; grid-template-columns:auto 1fr auto; gap:8px; align-items:center; color:var(--muted); font-size:12px; margin-top:8px; }
.range-wrap span { font-size:11px; text-transform:uppercase; letter-spacing:.04em; color:var(--soft); }
.month-slider-panel input[type="range"] { width:100%; }
.main-title {
  margin:15px 2px 9px;
  display:flex;
  justify-content:space-between;
  gap:8px;
  align-items:end;
}
.main-title h2 { margin:0; font-size:19px; line-height:1.1; }
.main-title p { margin:4px 0 0; color:var(--muted); font-size:12px; }
.grid { display:grid; grid-template-columns:1fr; gap:10px; }
.card {
  contain:content;
  content-visibility:auto;
  contain-intrinsic-size:230px;
  border:1px solid var(--line);
  border-radius:var(--radius);
  background:linear-gradient(180deg,var(--panel),var(--panel2));
  padding:12px;
  overflow:hidden;
  box-shadow:0 10px 26px rgba(0,0,0,.18);
}
.card-head { display:flex; gap:10px; align-items:center; min-width:0; }
.avatar {
  flex:0 0 42px;
  width:42px;
  height:42px;
  border-radius:15px;
  background:linear-gradient(135deg,#f7b733,#ff3d87,#8b5cff);
  color:white;
  display:grid;
  place-items:center;
  font-weight:900;
  text-transform:uppercase;
}
.info { min-width:0; flex:1; }
.user { font-weight:850; font-size:16px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.meta { color:var(--muted); font-size:12px; display:flex; gap:7px; flex-wrap:wrap; margin-top:3px; }
.date-text { font-size:24px; line-height:1.12; font-weight:850; color:var(--text); display:block; flex-basis:100%; letter-spacing:-.02em; }
.pill {
  display:inline-flex;
  align-items:center;
  gap:4px;
  border:1px solid var(--line);
  border-radius:999px;
  padding:2px 7px;
  background:#0d0e15;
  color:#e6e6ee;
  text-transform:uppercase;
  font-size:10px;
  letter-spacing:.04em;
}
.preview {
  margin-top:11px;
  border:1px solid #303244;
  background:linear-gradient(135deg,rgba(255,61,135,.12),rgba(139,92,255,.08)),#0d0e15;
  border-radius:16px;
  padding:9px;
  min-height:86px;
  display:grid;
  grid-template-columns:78px 1fr;
  align-items:center;
  gap:11px;
}
.thumb-frame {
  position:relative;
  width:78px;
  height:78px;
  border-radius:15px;
  overflow:hidden;
  background:linear-gradient(135deg,#405de6,#833ab4,#fd1d1d,#fcb045);
  border:1px solid rgba(255,255,255,.12);
  flex:0 0 auto;
}
.auto-thumb {
  width:100%;
  height:100%;
  display:block;
  object-fit:cover;
  background:#111;
}
.thumb-fallback {
  display:none;
  position:absolute;
  inset:0;
  place-items:center;
  color:white;
  font-size:28px;
  font-weight:900;
  background:linear-gradient(135deg,#405de6,#833ab4,#fd1d1d,#fcb045);
}
.thumb-frame.thumb-broken .auto-thumb { display:none; }
.thumb-frame.thumb-broken .thumb-fallback { display:grid; }
.preview b { display:block; font-size:14px; }
.preview small { display:block; color:var(--soft); overflow-wrap:anywhere; font-size:11px; margin-top:2px; }
.preview .hint { color:var(--muted); font-size:10px; margin-top:4px; }
.actions { display:grid; grid-template-columns:1fr 1fr 1fr; gap:8px; margin-top:10px; }
.embed-slot { margin-top:10px; display:block; min-height:1px; }
.embed-slot:not(.loaded)::before { content:"Embed auto-loads when this card reaches the screen…"; display:block; color:var(--muted); font-size:11px; padding:8px 10px; border:1px dashed rgba(255,255,255,.10); border-radius:12px; background:rgba(255,255,255,.03); }
.embed-slot.loaded::before { content:none; }
.embed-slot.loaded { display:block; }
.ig-frame { width:100%; min-height:520px; border:0; border-radius:16px; background:#fff; display:block; }
.load-more { width:100%; margin:14px 0 34px; }
.empty { border:1px dashed var(--line); border-radius:var(--radius); padding:22px; color:var(--muted); text-align:center; background:#101018; }
.footer-note { color:var(--soft); font-size:12px; margin:18px 0 28px; }
.toast {
  position:fixed;
  left:50%;
  bottom:calc(92px + var(--safe-bottom));
  transform:translateX(-50%);
  background:#1f2130;
  border:1px solid var(--line);
  color:#fff;
  border-radius:999px;
  padding:10px 14px;
  z-index:60;
  display:none;
  max-width:92vw;
  text-align:center;
  box-shadow:0 12px 40px rgba(0,0,0,.35);
}
.toast.show { display:block; }
.bottom-dock {
  position:fixed;
  left:0;
  right:0;
  bottom:0;
  z-index:55;
  display:none;
  padding:8px 10px calc(8px + var(--safe-bottom));
  background:linear-gradient(180deg,rgba(8,8,13,0),rgba(8,8,13,.98) 18%,rgba(8,8,13,1));
}
.dock-inner {
  max-width:520px;
  margin:0 auto;
  display:grid;
  grid-template-columns:1fr 1.15fr 1fr .78fr;
  gap:7px;
  border:1px solid rgba(255,255,255,.08);
  background:rgba(18,19,28,.95);
  backdrop-filter:blur(14px);
  -webkit-backdrop-filter:blur(14px);
  border-radius:24px;
  padding:7px;
  box-shadow:0 -10px 35px rgba(0,0,0,.35);
}
.bottom-dock button { min-height:46px; padding:8px 7px; font-size:12px; font-weight:750; }
.mobile-jump {
  display:none;
  margin:8px 0 4px;
  border:1px solid rgba(255,255,255,.08);
  border-radius:18px;
  padding:8px;
  background:#0d0e15;
}
.mobile-jump select { margin-top:0; }
details.mobile-filters { display:none; }

@media (min-width:720px) {
  .grid { grid-template-columns:repeat(2,minmax(0,1fr)); }
  .controls { grid-template-columns:1.1fr .7fr .7fr; align-items:end; }
  .hero { padding:16px; }
  h1 { font-size:28px; }
}

@media (max-width:560px) {
  body { padding-bottom:calc(92px + var(--safe-bottom)); }
  .app { padding:0 9px 10px; }
  .topbar {
    position:relative;
    top:auto;
    margin:0 -9px;
    padding:0 9px 8px;
    border-bottom:0;
    background:linear-gradient(180deg,#10111a,#08080d);
  }
  .hero {
    border-radius:0 0 24px 24px;
    border-left:0;
    border-right:0;
    border-top:0;
    padding:12px 10px 10px;
    box-shadow:none;
  }
  .hero-head { align-items:center; }
  h1 { font-size:18px; margin:0; }
  .sub { display:none; }
  .stats {
    display:flex;
    overflow-x:auto;
    gap:7px;
    margin-top:9px;
    padding-bottom:1px;
    -webkit-overflow-scrolling:touch;
  }
  .stat { flex:0 0 auto; min-width:84px; padding:7px 9px; border-radius:999px; }
  .stat b { display:inline; font-size:13px; margin-right:4px; }
  .stat span { font-size:11px; }
  .controls {
    grid-template-columns:1fr 1fr;
    gap:7px;
    margin-top:8px;
  }
  .controls label:nth-child(3) { grid-column:1 / -1; }
  label { font-size:11px; }
  input, select { min-height:43px; border-radius:13px; padding:10px 11px; font-size:14px; }
  .row { display:none; }
  .range-wrap { display:grid; margin-top:7px; }
  .month-row { display:none; }
  .month-slider-panel { margin-top:7px; border-radius:16px; padding:8px; }
  .month-slider-top { gap:7px; }
  .mobile-jump { display:block; }
  .main-title { position:relative; top:auto; z-index:auto; margin:0 -9px 8px; padding:9px 10px; background:rgba(8,8,13,.96); border-bottom:1px solid var(--line); align-items:center; }
  .main-title h2 { font-size:17px; }
  .main-title p { font-size:11px; }
  .main-title #topBtn { display:none; }
  .grid { gap:8px; }
  .card { border-radius:17px; padding:10px; contain-intrinsic-size:205px; }
  .avatar { flex-basis:38px; width:38px; height:38px; border-radius:13px; }
  .user { font-size:15px; }
  .meta { font-size:11px; gap:5px; }
  .date-text { font-size:22px; line-height:1.1; flex-basis:100%; }
  .pill { font-size:9px; padding:2px 6px; }
  .preview { min-height:74px; padding:7px; border-radius:14px; margin-top:9px; grid-template-columns:64px 1fr; gap:9px; }
  .thumb-frame { width:64px; height:64px; border-radius:13px; }
  .thumb-fallback { font-size:22px; }
  .preview b { font-size:13px; }
  .preview small { font-size:10px; line-height:1.25; }
  .actions { grid-template-columns:1fr 1fr; gap:7px; }
  .actions .copy-link { grid-column:1 / -1; }
  .btn.small, button.small { min-height:40px; font-size:12px; padding:8px 10px; }
  .ig-frame { min-height:460px; border-radius:14px; }
  .load-more { margin-bottom:16px; min-height:48px; }
  .footer-note { font-size:11px; margin-bottom:8px; }
  .bottom-dock { display:block; }
  .toast { bottom:calc(96px + var(--safe-bottom)); }
}

@media (max-width:360px) {
  .controls { grid-template-columns:1fr; }
  .actions { grid-template-columns:1fr; }
  .actions .copy-link { grid-column:auto; }
  .dock-inner { grid-template-columns:1fr 1fr 1fr 1fr; gap:5px; padding:6px; }
  .bottom-dock button { font-size:11px; padding-left:4px; padding-right:4px; }
}



/* Left-side fast page scroller */
.left-page-scroller {
  position:fixed;
  left:8px;
  top:92px;
  bottom:calc(96px + var(--safe-bottom));
  z-index:58;
  width:42px;
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:7px;
  padding:7px 5px;
  border:1px solid rgba(255,255,255,.10);
  border-radius:999px;
  background:rgba(12,13,20,.72);
  backdrop-filter:blur(12px);
  -webkit-backdrop-filter:blur(12px);
  box-shadow:0 10px 30px rgba(0,0,0,.30);
}
.left-page-scroller button {
  width:30px;
  height:30px;
  min-height:30px;
  padding:0;
  border-radius:50%;
  font-size:13px;
  line-height:1;
  background:#171925;
}
.left-page-scroller .side-track {
  flex:1;
  min-height:150px;
  display:flex;
  align-items:center;
  justify-content:center;
}
.left-page-scroller input[type="range"] {
  width:30px;
  height:100%;
  min-height:150px;
  padding:0;
  writing-mode:vertical-lr;
  direction:rtl;
  -webkit-appearance:slider-vertical;
  appearance:slider-vertical;
  accent-color:var(--accent);
  background:transparent;
}
.left-page-scroller .side-label {
  writing-mode:vertical-rl;
  transform:rotate(180deg);
  color:var(--muted);
  font-size:9px;
  font-weight:800;
  letter-spacing:.08em;
  text-transform:uppercase;
  user-select:none;
}
@media (min-width:980px) {
  .left-page-scroller { left:18px; top:120px; bottom:28px; }
}
@media (max-width:560px) {
  .app { padding-left:50px; }
  .topbar { margin-left:-50px; padding-left:50px; }
  .main-title { margin-left:-50px; padding-left:52px; }
  .left-page-scroller {
    left:6px;
    top:74px;
    bottom:calc(94px + var(--safe-bottom));
    width:38px;
    padding:6px 4px;
    gap:6px;
    background:rgba(12,13,20,.78);
  }
  .left-page-scroller button { width:28px; height:28px; min-height:28px; font-size:12px; }
  .left-page-scroller .side-track { min-height:120px; }
  .left-page-scroller input[type="range"] { width:28px; min-height:120px; }
}
@media (max-width:360px) {
  .app { padding-left:44px; }
  .topbar { margin-left:-44px; padding-left:44px; }
  .main-title { margin-left:-44px; padding-left:46px; }
  .left-page-scroller { left:4px; width:34px; }
  .left-page-scroller button { width:25px; height:25px; min-height:25px; }
}

@media (prefers-reduced-motion:reduce) {
  * { scroll-behavior:auto!important; transition:none!important; animation:none!important; }
}
</style>
</head>
<body>
<div class="app">
  <div class="topbar">
    <section class="hero">
      <div class="hero-head">
        <div>
          <h1>Pinecon Instagram likes</h1>
          <p class="sub">Phone-safe Pinecon liked-posts reader with month slider, search, and auto-loading Instagram embeds.</p>
        </div>
      </div>
      <div class="stats" id="stats"></div>
      <div class="controls">
        <label>Month
          <select id="monthSelect"></select>
        </label>
        <label>Type
          <select id="typeSelect">
            <option value="all">All types</option>
            <option value="post">Posts only</option>
            <option value="reel">Reels only</option>
            <option value="tv">TV only</option>
          </select>
        </label>
        <label>Search username / link
          <input id="searchBox" type="search" placeholder="Search all months...">
        </label>
      </div>
      <div class="mobile-jump">
        <select id="mobileMonthSelect" aria-label="Jump to month"></select>
      </div>
      <div class="month-slider-panel" aria-label="Month slider navigation">
        <div class="month-slider-top">
          <button id="prevBtn" class="small ghost" type="button">←</button>
          <div class="slider-month-label">
            <b id="sliderMonthLabel">Month</b>
            <small id="sliderMonthCount">Slide to jump months</small>
          </div>
          <button id="nextBtn" class="small ghost" type="button">→</button>
        </div>
        <div class="range-wrap">
          <span>new</span>
          <input id="monthRange" type="range" min="0" value="0" aria-label="Month slider">
          <span>old</span>
        </div>
        <button id="embedVisibleBtn" class="small good" type="button" style="width:100%;margin-top:8px">Reload visible embeds</button>
      </div>
    </section>
  </div>

  <div class="main-title">
    <div>
      <h2 id="viewTitle">Loading...</h2>
      <p id="viewSub"></p>
    </div>
    <button id="topBtn" class="small">Top</button>
  </div>

  <main id="list" class="grid"></main>
  <button id="loadMoreBtn" class="load-more primary">Load more</button>
  <div id="sentinel" style="height:1px"></div>
  <p class="footer-note">Instagram embeds auto-load as cards reach the screen. They need internet access and Instagram may block/limit removed, private, or login-required posts. Compact cards and direct links stay available offline.</p>
</div>


<div class="left-page-scroller" aria-label="Fast page scroller">
  <button id="sideTopBtn" class="ghost" type="button" title="Top">↑</button>
  <div class="side-track">
    <input id="pageScrollRange" type="range" min="0" max="1" value="0" aria-label="Scroll through page">
  </div>
  <div class="side-label">scroll</div>
  <button id="sideBottomBtn" class="ghost" type="button" title="Bottom">↓</button>
</div>

<div class="bottom-dock" aria-label="Mobile quick navigation">
  <div class="dock-inner">
    <button id="dockPrevBtn" class="ghost" type="button">← Month</button>
    <button id="dockEmbedBtn" class="good" type="button">Reload</button>
    <button id="dockNextBtn" class="ghost" type="button">Month →</button>
    <button id="dockTopBtn" class="primary" type="button">Top</button>
  </div>
</div>
