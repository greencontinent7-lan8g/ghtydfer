-c8"},{"i":830,"u":"bhuvan.bam22","url":"https://www.instagram.com/p/B8WCP6kpfxw/","type":"post","reaction":"👍","date":"09 February 2020, 11:53 AM","iso":"2020-02-09T11:53:00","month":"2020-02","monthLabel":"February 2020","embed":"https://www.instagram.com/p/B8WCP6kpfxw/embed","code":"B8WCP6kpfxw"}];
const MONTHS = [{"key":"2023-09","label":"September 2023","count":1},{"key":"2021-04","label":"April 2021","count":1},{"key":"2021-03","label":"March 2021","count":2},{"key":"2021-01","label":"January 2021","count":8},{"key":"2020-12","label":"December 2020","count":10},{"key":"2020-11","label":"November 2020","count":31},{"key":"2020-10","label":"October 2020","count":18},{"key":"2020-09","label":"September 2020","count":57},{"key":"2020-08","label":"August 2020","count":93},{"key":"2020-07","label":"July 2020","count":98},{"key":"2020-06","label":"June 2020","count":63},{"key":"2020-05","label":"May 2020","count":49},{"key":"2020-04","label":"April 2020","count":218},{"key":"2020-03","label":"March 2020","count":177},{"key":"2020-02","label":"February 2020","count":4}];
const STATS = {"total":830,"months":15,"posts":690,"reels":66,"tv":74,"rangeStart":"09 February 2020, 11:53 AM","rangeEnd":"24 September 2023, 11:01 PM"};

const state = {
  monthIndex: 0,
  type: 'all',
  query: '',
  rendered: 0,
  list: [],
  batch: (navigator.deviceMemory && navigator.deviceMemory <= 2) ? 18 : 30,
  autoEmbedBudget: 0
};

const $ = (id) => document.getElementById(id);
const listEl = $('list');
const monthSelect = $('monthSelect');
const monthRange = $('monthRange');
const mobileMonthSelect = $('mobileMonthSelect');
const typeSelect = $('typeSelect');
const searchBox = $('searchBox');
const loadMoreBtn = $('loadMoreBtn');
const viewTitle = $('viewTitle');
const viewSub = $('viewSub');
const toast = $('toast');

function esc(s) {
  return String(s ?? '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

function showToast(msg) {
  toast.textContent = msg;
  toast.classList.add('show');
  clearTimeout(showToast.t);
  showToast.t = setTimeout(() => toast.classList.remove('show'), 1900);
}

function initStats() {
  $('stats').innerHTML = `
    <div class="stat"><b>${STATS.total}</b><span>likes</span></div>
    <div class="stat"><b>${STATS.months}</b><span>months</span></div>
    <div class="stat"><b>${STATS.posts}</b><span>posts</span></div>
    <div class="stat"><b>${STATS.reels + STATS.tv}</b><span>reels/tv</span></div>
  `;
}

function initMonths() {
  monthRange.max = Math.max(0, MONTHS.length - 1);
  const monthOptions = MONTHS.map((m,i)=>`<option value="${i}">${esc(m.label)} (${m.count})</option>`).join('');
  monthSelect.innerHTML = monthOptions;
  mobileMonthSelect.innerHTML = monthOptions;
}

function setMonth(i) {
  state.monthIndex = Math.max(0, Math.min(MONTHS.length - 1, i));
  monthSelect.value = state.monthIndex;
  mobileMonthSelect.value = state.monthIndex;
  monthRange.value = state.monthIndex;
  const m = MONTHS[state.monthIndex];
  $('sliderMonthLabel').textContent = m.label;
  $('sliderMonthCount').textContent = `${m.count} item(s) · ${state.monthIndex + 1} / ${MONTHS.length}`;
  renderReset();
  window.scrollTo({top:0, behavior:'smooth'});
}

function getFiltered() {
  let arr = DATA;
  const q = state.query.trim().toLowerCase();
  if (q) {
    arr = arr.filter(e => (e.u + ' ' + e.url + ' ' + e.code).toLowerCase().includes(q));
  } else {
    const m = MONTHS[state.monthIndex];
    arr = arr.filter(e => e.month === m.key);
  }
  if (state.type !== 'all') arr = arr.filter(e => e.type === state.type);
  return arr;
}

function mediaEmoji(type) {
  if (type === 'reel') return '▶';
  if (type === 'tv') return '▣';
  return '◎';
}

function thumbUrl(e) {
  // Instagram's lightweight media endpoint often returns the public preview image.
  // If a post is private/deleted/blocked, the card falls back to the gradient icon.
  return String(e.url || '').replace(/\/$/, '') + '/media/?size=m';
}

function makeCard(e, autoEmbed) {
  const article = document.createElement('article');
  article.className = 'card';
  const first = (e.u || '?').replace(/^_+/, '').slice(0,1) || '?';
  article.innerHTML = `
    <div class="card-head">
      <div class="avatar">${esc(first)}</div>
      <div class="info">
        <div class="user">${esc(e.u)}</div>
        <div class="meta">
          <span class="date-text">${esc(e.date)}</span>
          <span class="pill">${mediaEmoji(e.type)} ${esc(e.type)}</span>
          <span class="pill">#${e.i}</span>
        </div>
      </div>
    </div>
    <div class="actions">
      <a class="btn small primary" href="${esc(e.url)}" target="_blank" rel="noopener">Open</a>
      <button class="small good embed-one" type="button">Reload embed</button>
      <button class="small ghost copy-link" type="button">Copy</button>
    </div>
    <div class="embed-slot" data-embed="${esc(e.embed)}"></div>
  `;
  article.querySelector('.embed-one').addEventListener('click', () => loadEmbed(article.querySelector('.embed-slot')));
  article.querySelector('.copy-link').addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(e.url);
      showToast('Copied Instagram link');
    } catch(err) {
      showToast('Copy failed — open link instead');
    }
  });
  if (autoEmbed) {
    setTimeout(() => loadEmbed(article.querySelector('.embed-slot')), 120);
  }
  return article;
}

function loadEmbed(slot) {
  if (!slot || slot.dataset.loaded === '1') return;
  const src = slot.dataset.embed;
  if (!src) {
    showToast('No embed URL found');
    return;
  }
  slot.dataset.loaded = '1';
  slot.classList.add('loaded');
  slot.innerHTML = `<iframe class="ig-frame" src="${esc(src)}" loading="lazy" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen scrolling="no"></iframe>`;
}

function loadVisibleEmbeds() {
  const slots = [...document.querySelectorAll('.embed-slot:not(.loaded)')];
  const visible = slots.filter(s => {
    const r = s.getBoundingClientRect();
    return r.top < innerHeight + 1200 && r.bottom > -400;
  });
  const target = visible.length ? visible : slots.slice(0, state.batch);
  target.slice(0, 12).forEach((slot, i) => setTimeout(() => loadEmbed(slot), i * 140));
  showToast(`Loading ${Math.min(target.length,12)} embed(s)`);
}

const embedIO = 'IntersectionObserver' in window ? new IntersectionObserver(entries => {
  entries.forEach(entry => {
    if (!entry.isIntersecting) return;
    embedIO.unobserve(entry.target);
    setTimeout(() => loadEmbed(entry.target), 80);
  });
}, {rootMargin:'1100px 0px 900px 0px', threshold:0.01}) : null;

function armAutoEmbeds(root = document) {
  const slots = [...root.querySelectorAll('.embed-slot:not(.loaded):not([data-auto-armed])')];
  slots.forEach((slot, i) => {
    slot.dataset.autoArmed = '1';
    if (embedIO) {
      embedIO.observe(slot);
    } else {
      // Older Android fallback: auto-load a few at a time instead of waiting for taps.
      setTimeout(() => loadEmbed(slot), Math.min(i, 10) * 180);
    }
  });
}

function renderReset() {
  state.list = getFiltered();
  state.rendered = 0;
  listEl.textContent = '';
  const month = MONTHS[state.monthIndex];
  if (state.query.trim()) {
    viewTitle.textContent = `Search results`;
    viewSub.textContent = `${state.list.length} match(es) across all months`;
  } else {
    viewTitle.textContent = `${month.label}`;
    viewSub.textContent = `${state.list.length} item(s) in this view`;
  }
  if (!state.list.length) {
    listEl.innerHTML = '<div class="empty">No matching Instagram likes found.</div>';
    loadMoreBtn.style.display = 'none';
    return;
  }
  loadMoreBtn.style.display = '';
  renderMore();
}

function renderMore() {
  const frag = document.createDocumentFragment();
  const end = Math.min(state.rendered + state.batch, state.list.length);
  let autoLeft = state.autoEmbedBudget;
  for (let i = state.rendered; i < end; i++) {
    const auto = autoLeft > 0;
    if (auto) autoLeft--;
    frag.appendChild(makeCard(state.list[i], auto));
  }
  state.rendered = end;
  listEl.appendChild(frag);
  armAutoEmbeds(listEl);
  setTimeout(loadVisibleEmbeds, 260);
  loadMoreBtn.disabled = state.rendered >= state.list.length;
  loadMoreBtn.textContent = state.rendered >= state.list.length ? `All loaded (${state.rendered})` : `Load more (${state.rendered} / ${state.list.length})`;
}

function debounce(fn, wait=180) {
  let t;
  return (...args) => {
    clearTimeout(t);
    t = setTimeout(() => fn(...args), wait);
  };
}

function jumpToMonthValue(v) {
  searchBox.value = '';
  state.query = '';
  setMonth(Number(v));
}
monthSelect.addEventListener('change', e => jumpToMonthValue(e.target.value));
mobileMonthSelect.addEventListener('change', e => jumpToMonthValue(e.target.value));
monthRange.addEventListener('input', e => jumpToMonthValue(e.target.value));
typeSelect.addEventListener('change', e => {
  state.type = e.target.value;
  renderReset();
});
searchBox.addEventListener('input', debounce(e => {
  state.query = e.target.value;
  renderReset();
}, 220));
$('prevBtn').addEventListener('click', () => {
  searchBox.value = '';
  state.query = '';
  setMonth(state.monthIndex - 1);
});
$('nextBtn').addEventListener('click', () => {
  searchBox.value = '';
  state.query = '';
  setMonth(state.monthIndex + 1);
});
$('topBtn').addEventListener('click', () => window.scrollTo({top:0, behavior:'smooth'}));
$('dockTopBtn').addEventListener('click', () => window.scrollTo({top:0, behavior:'smooth'}));
$('dockPrevBtn').addEventListener('click', () => jumpToMonthValue(state.monthIndex - 1));
$('dockNextBtn').addEventListener('click', () => jumpToMonthValue(state.monthIndex + 1));
$('dockEmbedBtn').addEventListener('click', loadVisibleEmbeds);
$('embedVisibleBtn').addEventListener('click', loadVisibleEmbeds);
loadMoreBtn.addEventListener('click', renderMore);

const io = 'IntersectionObserver' in window ? new IntersectionObserver(entries => {
  if (entries.some(e => e.isIntersecting) && !loadMoreBtn.disabled) renderMore();
}, {rootMargin:'800px'}) : null;
if (io) io.observe($('sentinel'));
else addEventListener('scroll', () => {
  if (innerHeight + scrollY > document.body.offsetHeight - 900 && !loadMoreBtn.disabled) renderMore();
}, {passive:true});


function initQuickScroller() {
  const track = $('scrollTrack');
  const thumb = $('scrollThumb');
  const up = $('scrollUpBtn');
  const down = $('scrollDownBtn');
  if (!track || !thumb || !up || !down) return;

  let dragging = false;

  function maxScroll() {
    return Math.max(1, document.documentElement.scrollHeight - innerHeight);
  }

  function syncThumb() {
    const max = maxScroll();
    const trackH = track.clientHeight;
    const ratio = Math.min(1, innerHeight / Math.max(document.documentElement.scrollHeight, innerHeight));
    const thumbH = Math.max(38, Math.round(trackH * ratio));
    const free = Math.max(1, trackH - thumbH);
    const y = Math.round((scrollY / max) * free);
    thumb.style.height = thumbH + 'px';
    thumb.style.transform = `translateY(${y}px)`;
    track.setAttribute('aria-valuenow', String(Math.round((scrollY / max) * 100)));
  }

  function scrollByPage(dir) {
    window.scrollBy({top: dir * Math.max(260, innerHeight * 0.72), behavior:'smooth'});
  }

  function goFromClientY(clientY) {
    const rect = track.getBoundingClientRect();
    const thumbH = thumb.offsetHeight || 44;
    const free = Math.max(1, rect.height - thumbH);
    const y = Math.max(0, Math.min(free, clientY - rect.top - thumbH / 2));
    window.scrollTo({top: (y / free) * maxScroll(), behavior: dragging ? 'auto' : 'smooth'});
  }

  up.addEventListener('click', () => scrollByPage(-1));
  down.addEventListener('click', () => scrollByPage(1));
  track.addEventListener('pointerdown', e => {
    dragging = true;
    track.setPointerCapture?.(e.pointerId);
    goFromClientY(e.clientY);
    e.preventDefault();
  });
  track.addEventListener('pointermove', e => {
    if (!dragging) return;
    goFromClientY(e.clientY);
    e.preventDefault();
  });
  track.addEventListener('pointerup', e => {
    dragging = false;
    track.releasePointerCapture?.(e.pointerId);
  });
  track.addEventListener('pointercancel', () => dragging = false);
  addEventListener('scroll', syncThumb, {passive:true});
  addEventListener('resize', syncThumb, {passive:true});
  new MutationObserver(syncThumb).observe(document.body, {childList:true, subtree:true});
  syncThumb();
}

initStats();
initMonths();
setMonth(0);
initQuickScroller();
</script>
